using System;
using System.Globalization;

public class ComplexNumber
{
    private static double eps = 1e-6;
    public double real { get; }
    public double imaginary { get; }
    
    public ComplexNumber(double r, double im)
    {
        real = r;
        imaginary = im;
    }
    private static bool IsZero(double c)
    {
        return Math.Abs(c) < eps;
    }

    private static string FormatNum(double c)
    {
        return c.ToString("0.######", CultureInfo.InvariantCulture);
    }
    private static string FormatImagine(double c)
    {
        if(Math.Abs(c) < (1 + eps))
        {
            return "i";
        }
        return FormatNum(Math.Abs(c)) + "i";
    }

    public override string ToString()
    {
        bool rZero = IsZero(real), imZero = IsZero(imaginary);
        if (rZero && imZero)
        {
            return "0";
        }
        if (rZero)
        {
            string sign = (imaginary < 0 ? "-" : "");
            return sign + FormatNum(imaginary);
        }
        if (imZero)
        {
            return FormatNum(real);
        }

        string imsign = (imaginary < 0 ? "-" : "+");
        return FormatNum(real) + ' ' + imsign + ' ' + FormatImagine(Math.Abs(imaginary));
    }


    public static ComplexNumber operator +(ComplexNumber first, ComplexNumber second)
    {
        return new ComplexNumber(first.real + second.real, first.imaginary + second.imaginary);
    }
    public static ComplexNumber operator -(ComplexNumber first, ComplexNumber second)
    {
        return new ComplexNumber(first.real - second.real, first.imaginary - second.imaginary);
    }
    public static ComplexNumber operator *(ComplexNumber first, ComplexNumber second)
    {
        double r = first.real * second.real - first.imaginary * second.imaginary;
        double im = first.real * second.imaginary + first.imaginary * second.real;
        return new ComplexNumber(r, im);
    }
    public static ComplexNumber operator /(ComplexNumber first, ComplexNumber second)
    {
        double down = second.real * second.real + second.imaginary * second.imaginary;
        if (IsZero(down))
        {
            throw new DivideByZeroException("Error: cannot be divided by 0.");
        }

        double r = (first.real * second.real + first.imaginary * second.imaginary) / down;
        double im = (first.imaginary * second.real + first.real * second.imaginary) / down;
        return new ComplexNumber(r, im);
    }
    
    public static double operator +(ComplexNumber num)
    {
        return Math.Sqrt(num.real * num.real + num.imaginary *  num.imaginary);
    }
    public static ComplexNumber operator -(ComplexNumber num)
    {
        return new ComplexNumber(num.real, -num.imaginary);
    }
    public static bool operator ==(ComplexNumber first, ComplexNumber second)
    {
        if(first.real == second.real && first.imaginary == second.imaginary)
        {
            return true;
        }
        return false;
        if(first == null || second == null)
        {
            return false;
        }
    }
    public static bool operator !=(ComplexNumber first, ComplexNumber second)
    {
        return !(first == second);
    }
    public override bool Equals(object obj)
    {
        return (obj is ComplexNumber other && this == other);
    }
}

public class Program
{
    public static void Main()
    {
        ComplexNumber com1 = new ComplexNumber(1.01, 2);
        ComplexNumber com2 = new ComplexNumber(3, -4);
        ComplexNumber com3 = new ComplexNumber(0, 4);
        ComplexNumber com4 = new ComplexNumber(3, 0);

        Console.WriteLine("First number: " + com1);
        Console.WriteLine("Second number: " + com2);
        Console.WriteLine("Third number: " + com3);
        Console.WriteLine("Fourth number: " + com4);
        Console.WriteLine('\n');
        Console.WriteLine("Addition first and second numbers: " + (com1 + com2));
        Console.WriteLine("Subtraction first and second numbers: " + (com1 - com2));
        Console.WriteLine("Multiplication first and second numbers: " + (com1 * com2));
        Console.WriteLine("Division first and second numbers: " + (com1 / com2));
        Console.WriteLine('\n');
        Console.WriteLine("Absolute value of the first number: " + (+com1));
        Console.WriteLine("Сonjugate to the first number: " + (-com1));
        Console.WriteLine('\n');
        Console.WriteLine("first == second: " + (com1 == com2));
        Console.WriteLine("first != second: " + (com1 != com2));
        Console.WriteLine("first == (1.01, 2): " + (com1 == new ComplexNumber(1.01, 2)));

        //Проверка на запрет деления на 0:
        ComplexNumber com0 = new ComplexNumber(0, 0);
        Console.WriteLine("Division first number and zero: " + (com1 / com0));
    }
}
